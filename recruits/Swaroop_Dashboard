
<style>
*{box-sizing:border-box;margin:0;padding:0}
#dash{background:#0d0d0d;color:#d0d0d0;font-family:var(--font-sans,sans-serif);font-size:12px;border-radius:10px;padding:8px;display:grid;grid-template-columns:170px 1fr 170px;gap:7px}
.panel{background:#141414;border:0.5px solid #2a2a2a;border-radius:7px;padding:7px 9px}
.ptitle{font-size:9px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:#5a5a5a;margin-bottom:5px;border-bottom:0.5px solid #1e1e1e;padding-bottom:3px}
