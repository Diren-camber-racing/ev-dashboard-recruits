<script>
(function(){
const canvas=document.getElementById('tc');
const ctx=canvas.getContext('2d');

const rawPts=[
  [0.500,0.135],[0.520,0.095],[0.555,0.080],
  [0.600,0.075],[0.640,0.082],
  [0.660,0.120],[0.665,0.200],[0.660,0.310],[0.650,0.390],
  [0.635,0.440],[0.600,0.465],[0.565,0.460],
  [0.530,0.440],[0.505,0.410],[0.490,0.380],
  [0.470,0.370],[0.445,0.375],[0.425,0.390],
  [0.415,0.415],[0.420,0.440],[0.440,0.455],
  [0.465,0.455],[0.490,0.445],[0.505,0.460],
  [0.505,0.485],[0.490,0.500],
  [0.470,0.515],[0.450,0.540],[0.430,0.570],
  [0.415,0.610],[0.410,0.650],[0.415,0.700],
  [0.430,0.740],[0.455,0.760],[0.480,0.760],
  [0.500,0.745],[0.515,0.720],[0.520,0.690],
  [0.515,0.650],[0.505,0.620],
  [0.505,0.590],[0.510,0.570],[0.530,0.555],
  [0.555,0.545],[0.575,0.525],[0.580,0.498],
  [0.570,0.470],[0.550,0.450],[0.530,0.440],
  [0.535,0.420],[0.545,0.395],[0.550,0.360],
  [0.545,0.310],[0.535,0.250],[0.520,0.190],
  [0.510,0.150],[0.500,0.135]
];

const zoneColors=[
  '#cc2222','#cc2222','#555',
  '#550000','#cc2222','#cc2222',
  '#cc2222','#cc2222','#884400',
  '#555','#550000','#884400',
  '#884400','#555','#550000',
  '#884400','#555','#550000',
  '#555','#550000','#884400',
  '#884400','#884400','#555',
  '#550000','#884400','#cc2222',
  '#cc2222','#884400','#555',
  '#550000','#cc2222','#cc2222',
  '#cc2222','#884400','#555',
  '#550000','#884400','#cc2222',
  '#cc2222','#cc2222','#884400',
  '#555','#550000','#884400',
  '#cc2222','#555','#550000',
  '#884400','#cc2222','#cc2222',
  '#cc2222','#cc2222','#555',
  '#550000','#884400','#cc2222',
];

const speedMap=[
  120,129,80,70,110,129,
  129,129,100,70,70,90,
  90,80,70,80,85,70,
  70,75,80,85,88,80,
  80,85,90,85,80,75,
  70,75,80,88,100,95,
  90,80,75,70,85,90,
  95,100,95,85,80,75,
  80,90,100,110,120,125,
  129,129,120,115,
];

function getScaled(pts,W,H){
  const xs=pts.map(p=>p[0]),ys=pts.map(p=>p[1]);
  const minX=Math.min(...xs),maxX=Math.max(...xs);
  const minY=Math.min(...ys),maxY=Math.max(...ys);
  const pad=28;
  const sc=Math.min((W-pad*2)/(maxX-minX),(H-pad*2)/(maxY-minY));
  const ox=(W-(maxX-minX)*sc)/2-minX*sc;
  const oy=(H-(maxY-minY)*sc)/2-minY*sc;
  return pts.map(p=>[p[0]*sc+ox,p[1]*sc+oy]);
}

function cr(p0,p1,p2,p3,t){
  const t2=t*t,t3=t2*t;
  return[
    .5*((2*p1[0])+(-p0[0]+p2[0])*t+(2*p0[0]-5*p1[0]+4*p2[0]-p3[0])*t2+(-p0[0]+3*p1[0]-3*p2[0]+p3[0])*t3),
    .5*((2*p1[1])+(-p0[1]+p2[1])*t+(2*p0[1]-5*p1[1]+4*p2[1]-p3[1])*t2+(-p0[1]+3*p1[1]-3*p2[1]+p3[1])*t3)
  ];
}

function buildSegs(scaled){
  const segs=[],n=scaled.length;
  for(let i=0;i<n;i++){
    const p0=scaled[(i-1+n)%n],p1=scaled[i],p2=scaled[(i+1)%n],p3=scaled[(i+2)%n];
    for(let s=0;s<16;s++){
      segs.push({from:cr(p0,p1,p2,p3,s/16),to:cr(p0,p1,p2,p3,(s+1)/16),color:zoneColors[i%zoneColors.length],speed:speedMap[i%speedMap.length]});
    }
  }
  return segs;
}

function interpPos(segs,frac){
  const idx=Math.min(Math.floor(frac*segs.length),segs.length-1);
  const s=segs[idx],loc=(frac*segs.length)-idx;
  return[s.from[0]*(1-loc)+s.to[0]*loc,s.from[1]*(1-loc)+s.to[1]*loc,s.speed,s.color];
}

const LAP_MS=149050;
let lapStart=performance.now();
let lapsDone=0;
let lapHistory=[];
let bestLap=null;
let lastLap=null;
let spdSamples=[];
let socStart=82;
let totalRegen=0;

function fmtTime(ms){
  const m=Math.floor(ms/60000),s=Math.floor((ms%60000)/1000),cs=Math.floor((ms%1000)/10);
  return `${m}:${String(s).padStart(2,'0')}.${String(cs).padStart(2,'0')}`;
}

function buildRPMBar(){
  const bar=document.getElementById('rpm-bar');
  if(bar._built)return;
  for(let i=0;i<20;i++){
    const d=document.createElement('div');
    d.className='rpm-seg';
    const pct=i/20;
    d.style.background=pct<0.6?'#3a1a1a':pct<0.8?'#7a2a00':'#cc2222';
    d.style.minWidth='6px';d.style.height='100%';
    bar.appendChild(d);
  }
  bar._built=true;
}

function updateRPM(rpm){
  document.getElementById('rpm-disp').textContent=rpm.toLocaleString();
  const bar=document.getElementById('rpm-bar');
  const ratio=(rpm-3000)/(6000-3000);
  const lit=Math.round(ratio*20);
  [...bar.children].forEach((s,i)=>{s.style.opacity=i<lit?'1':'0.12';});
}

function updateLapHistory(){
  const el=document.getElementById('lap-hist');
  if(!lapHistory.length){el.innerHTML='<div style="color:#333;font-size:10px;padding:2px 0">No laps yet</div>';return;}
  el.innerHTML=lapHistory.slice(-4).map((lt,i,arr)=>{
    const num=lapsDone-arr.length+i+1;
    const isBest=bestLap&&lt===bestLap;
    return `<div class="lap-row"><span class="lap-num">Lap ${num}</span><span class="lap-t${isBest?' best':''}">${fmtTime(lt)}</span></div>`;
  }).join('');
}

function drawPanels(now,segs,frac,spd){
  const elapsed=now-lapStart+lapsDone*LAP_MS;

  const curLapMs=(now-lapStart)%LAP_MS;
  document.getElementById('live-lt').textContent=fmtTime(curLapMs);
  document.getElementById('cur-lap-time').textContent=fmtTime(curLapMs);

  document.getElementById('hud-spd').textContent=Math.round(spd);
  document.getElementById('spd-panel').textContent=Math.round(spd);

  spdSamples.push(spd);
  if(spdSamples.length>200)spdSamples.shift();
  const sMax=Math.round(Math.max(...spdSamples));
  const sMin=Math.round(Math.min(...spdSamples));
  const sAvg=Math.round(spdSamples.reduce((a,b)=>a+b,0)/spdSamples.length);
  document.getElementById('spd-max').textContent=sMax+' km/h';
  document.getElementById('spd-min').textContent=sMin+' km/h';
  document.getElementById('spd-avg').textContent=sAvg+' km/h';

  const rpmR=(spd-70)/(129-70);
  const rpm=Math.round(3265+rpmR*(6000-3265));
  updateRPM(rpm);

  const n=now/1000;
  const mt=Math.round(60+Math.sin(n*.3)*5);
  document.getElementById('motor-t').textContent=mt;
  document.getElementById('motor-bar').style.width=((mt-40)/80*100)+'%';
  document.getElementById('motor-bar').style.background=mt>80?'#cc2222':mt>70?'#884400':'#444';
  document.getElementById('inv-t').textContent=Math.round(72+Math.sin(n*.2)*4)+'?C';
  document.getElementById('sta-t').textContent=Math.round(56+Math.cos(n*.3)*3)+'?C';
  document.getElementById('mtr-st').textContent=mt>80?'Warning':'Nominal';
  document.getElementById('mtr-st').className='mv '+(mt>80?'red':'grey');

  const tyreC=(id,v)=>{
    const el=document.getElementById(id);el.textContent=v+'?C';
    el.style.color=v>85?'#cc2222':v>78?'#884400':'#888';
  };
  tyreC('tfl',Math.round(80+Math.sin(n*.5)*5));
  tyreC('tfr',Math.round(77+Math.cos(n*.4)*4));
  tyreC('trl',Math.round(73+Math.sin(n*.6)*4));
  tyreC('trr',Math.round(78+Math.cos(n*.5)*5));

  const socDecay=(now-performance.now()*0+lapsDone*(LAP_MS/3600000)*8);
  const soc=Math.max(20,Math.round(socStart-frac*6-lapsDone*6));
  document.getElementById('soc-num').textContent=soc;
  document.getElementById('soc-bar').style.width=soc+'%';
  document.getElementById('soc-bar').style.background=soc>50?'#cc2222':soc>25?'#884400':'#ff3333';
  const cur=Math.round(100+((spd-70)/(129-70))*80);
  document.getElementById('pack-v').textContent=(288.4-(100-soc)*0.2).toFixed(1)+' V';
  document.getElementById('pack-i').textContent=cur+' A';
  document.getElementById('pack-p').textContent=((cur*288)/1000).toFixed(1)+' kW';

  const cm=Math.round(36+Math.sin(n*.1)*2);
  document.getElementById('cell-max').textContent=Math.round(38+Math.sin(n*.15)*1.5)+'?C';
  document.getElementById('cell-min').textContent=Math.round(34+Math.cos(n*.12)*1)+'?C';
  document.getElementById('cell-avg').textContent=cm+'?C';
  document.getElementById('cell-d').textContent=(Math.round((38+Math.sin(n*.15)*1.5)-(34+Math.cos(n*.12)*1)*10)/10).toFixed(1)+'?C';
  document.getElementById('pack-amb').textContent=Math.round(30+Math.sin(n*.05))+'?C';

  document.getElementById('lat-g').textContent=(0.8+Math.abs(Math.sin(n*.7))*0.8).toFixed(1)+' g';
  document.getElementById('lon-g').textContent=(0.2+Math.abs(Math.cos(n*.5))*0.9).toFixed(1)+' g';
  document.getElementById('steer').textContent=Math.round(Math.sin(n*.4)*35)+'?';

  const eUsed=(0.12+lapsDone*0.85+frac*0.85).toFixed(2);
  totalRegen=Math.max(totalRegen,(0.03+lapsDone*0.18+frac*0.18));
  document.getElementById('e-used').textContent=eUsed+' kWh';
  document.getElementById('regen').textContent=totalRegen.toFixed(2)+' kWh';
  document.getElementById('est-range').textContent=Math.max(1,Math.round(14-lapsDone))+' laps';

  const s1t=Math.round(27000+Math.random()*2000);
  const s2t=Math.round(51000+Math.random()*2000);
  if(frac>0.33)document.getElementById('s1').textContent=fmtTime(s1t);
  if(frac>0.66)document.getElementById('s2').textContent=fmtTime(s2t);
  if(frac>0.95)document.getElementById('s3').textContent=fmtTime(LAP_MS-s1t-s2t);

  if(bestLap){
    const delta=curLapMs-bestLap;
    const dEl=document.getElementById('delta');
    dEl.textContent=(delta>=0?'+':'')+fmtTime(Math.abs(delta));
    dEl.className='mv '+(delta<0?'red':'grey');
  }

  document.getElementById('laps-done').textContent=lapsDone;
  document.getElementById('badge-laps').textContent=lapsDone;
}

function resize(){
  const rect=canvas.parentElement.getBoundingClientRect();
  canvas.width=rect.width;
  canvas.height=Math.max(rect.width*0.52,210);
}

function draw(now){
  resize();
  const W=canvas.width,H=canvas.height;
  const scaled=getScaled(rawPts,W,H);
  const segs=buildSegs(scaled);

  const elapsed=now-lapStart;
  if(elapsed>=LAP_MS){
    lapsDone++;
    const lt=LAP_MS;
    lapHistory.push(lt+Math.round((Math.random()-.5)*800));
    if(!bestLap||lapHistory[lapHistory.length-1]<bestLap)bestLap=lapHistory[lapHistory.length-1];
    lastLap=lapHistory[lapHistory.length-1];
    document.getElementById('best-lap').textContent=fmtTime(bestLap||LAP_MS);
    document.getElementById('last-lap').textContent=fmtTime(lastLap);
    document.getElementById('best-lap').className='mv red';
    updateLapHistory();
    lapStart=now;
    spdSamples=[];
    document.getElementById('s1').textContent='?';
    document.getElementById('s2').textContent='?';
    document.getElementById('s3').textContent='?';
  }

  const frac=(elapsed%LAP_MS)/LAP_MS;
  const [cx,cy,spd]=interpPos(segs,frac);
  const currentSpd=spd+Math.sin(now/280)*3;

  ctx.clearRect(0,0,W,H);

  ctx.save();ctx.lineWidth=9;ctx.strokeStyle='#080808';ctx.lineJoin='round';ctx.lineCap='round';
  ctx.beginPath();segs.forEach((s,i)=>{if(i===0)ctx.moveTo(s.from[0],s.from[1]);ctx.lineTo(s.to[0],s.to[1]);});
  ctx.stroke();ctx.restore();

  ctx.save();ctx.lineWidth=3;ctx.lineJoin='round';ctx.lineCap='round';
  segs.forEach(s=>{
    ctx.strokeStyle=s.color;ctx.globalAlpha=0.9;
    ctx.beginPath();ctx.moveTo(s.from[0],s.from[1]);ctx.lineTo(s.to[0],s.to[1]);ctx.stroke();
  });
  ctx.restore();

  const sf=scaled[0];
  ctx.save();ctx.strokeStyle='#666';ctx.lineWidth=2;ctx.setLineDash([3,3]);ctx.globalAlpha=.5;
  ctx.beginPath();ctx.moveTo(sf[0]-7,sf[1]);ctx.lineTo(sf[0]+7,sf[1]);ctx.stroke();ctx.restore();

  const prevFrac=(frac-.002+1)%1;
  const [px,py]=interpPos(segs,prevFrac);
  const angle=Math.atan2(cy-py,cx-px);
  ctx.save();ctx.translate(cx,cy);ctx.rotate(angle);
  ctx.fillStyle='#cc2222';
  ctx.beginPath();ctx.roundRect(-5,-3.5,10,7,2.5);ctx.fill();
  ctx.fillStyle='#fff';ctx.beginPath();ctx.roundRect(-1.5,-1.5,4.5,3,1.5);ctx.fill();
  ctx.restore();

  buildRPMBar();
  drawPanels(now,segs,frac,currentSpd);
  requestAnimationFrame(draw);
}

updateLapHistory();
requestAnimationFrame(draw);
})();
</script>
