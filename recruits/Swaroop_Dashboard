.lap-badge-lbl{font-size:8px;color:#444}
.bottom-row{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;grid-column:1/4}
.tyre-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px;margin-top:3px}
.tyre-box{background:#0d0d0d;border:0.5px solid #1e1e1e;border-radius:4px;padding:3px 5px;text-align:center}
.tyre-box .tpos{font-size:8px;color:#444}
.tyre-box .ttemp{font-size:12px;font-weight:500;font-variant-numeric:tabular-nums}
.seg-legend{display:flex;gap:8px;flex-wrap:wrap;padding:3px 9px 5px}
.seg-dot{width:7px;height:7px;border-radius:50%;display:inline-block;margin-right:3px}
